# ── Vouch server ──
PORT=4021
# Public URL of the deployed server (used in .well-known docs, pinning, health checks)
VOUCH_PUBLIC_URL=https://vouch-8n14.onrender.com
# Address that receives x402 payments for score lookups (required to run the paywall)
VOUCH_PAY_TO_ADDRESS=0xYourReceivingAddress
# Price per /v1/score in native wei (default 0.000001 BTC)
VOUCH_SCORE_PRICE_WEI=1000000000000
# Operator key — used by `npm run register` (needs testnet3 gas)
VOUCH_PRIVATE_KEY=0x...
# Local dev only: skip on-chain payment verification
VOUCH_DEV_SKIP_PAYMENT=false

# ── GOAT network ──
GOAT_RPC_URL=https://rpc.testnet3.goat.network
GOAT_EXPLORER_API=https://explorer.testnet3.goat.network/api

# ── Gatekeeper demo agent (agent/) ──
# Key for the reference agent that pays Vouch and executes gated transfers (needs testnet3 gas)
GATEKEEPER_PRIVATE_KEY=0x...
VOUCH_URL=https://vouch-8n14.onrender.com
GATEKEEPER_MIN_SCORE=60
GATEKEEPER_MAX_AMOUNT_WEI=100000000000000

# ── LangChain / Gemini (optional — AI audit summaries) ──
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SUMMARY_TIMEOUT_MS=8000

# ── ERC-8004 registration (erc8004/) ──
# IPFS pinning for registration.json (`npm run pin`)
PINATA_JWT=
# Content-addressed URI from `npm run pin`, consumed by `npm run register`
AGENT_URI=ipfs://...
# Set true to bypass the pre-registration health gate (not recommended)
SKIP_HEALTHCHECK=false
